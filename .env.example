# Postgres connection — matches docker-compose.yml defaults.
DATABASE_URL=postgresql+psycopg://stockpred:stockpred@localhost:5432/stockpred

# Comma-separated list of US tickers to ingest.
WATCHLIST=AAPL,MSFT,NVDA

# https://newsapi.org/  (free tier: 100 req/day, headlines limited to last month)
NEWSAPI_KEY=

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Alpaca paper-trading credentials — https://alpaca.markets (Paper Trading dashboard)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Kill switch: set to 1 to stop the signal runner from submitting new orders.
RISK_HALT=0
