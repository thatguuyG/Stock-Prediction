# Postgres connection — matches docker-compose.yml defaults.
DATABASE_URL=postgresql+psycopg://stockpred:stockpred@localhost:5432/stockpred

# Comma-separated list of US tickers to ingest.
WATCHLIST=AAPL,MSFT,NVDA

# https://newsapi.org/  (free tier: 100 req/day, headlines limited to last month)
NEWSAPI_KEY=

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Alpaca paper-trading credentials.
# Step-by-step instructions for getting these keys:
#   docs/phase-3-execution.md#getting-alpaca-paper-trading-keys
# tl;dr: alpaca.markets → switch to Paper Trading → "Your API Keys" → Generate.
# The secret is shown ONCE — copy it immediately.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Kill switch: set to 1 to stop the signal runner from submitting new orders.
RISK_HALT=0

# FastAPI dashboard shim (Phase 3.5)
API_HOST=127.0.0.1
API_PORT=8000
